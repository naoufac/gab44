---
import type { Page } from '@/lib/types'
import { CATEGORY } from '@/lib/nav'

interface Props { page: Page }
const { page } = Astro.props as Props

const cat = CATEGORY[page.category]
const parentLabel = cat?.parent ?? 'gab44'
const parentHref = cat?.parentHref ?? '/'

// Build breadcrumbs JSON-LD
const ldBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'gab44', item: '/' },
    { '@type': 'ListItem', position: 2, name: parentLabel, item: parentHref },
    { '@type': 'ListItem', position: 3, name: page.display_title, item: `/${page.route}` },
  ],
}
const ldArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: page.display_title,
  description: page.description,
  author: { '@type': 'Person', name: 'Naoufal Chobah' },
  publisher: { '@type': 'Organization', name: 'gab44' },
  mainEntityOfPage: `/${page.route}`,
}

function paragraphs(body: string): string[] {
  if (!body) return []
  return body.split(/\n{2,}|\n/).map(s => s.trim()).filter(Boolean)
}
---
<article class="article">
  <nav class="crumbs" aria-label="Breadcrumb">
    <a href="/">gab44</a>
    <span>·</span>
    <a href={parentHref}>{parentLabel}</a>
    <span>·</span>
    <span class="crumb-current">{page.display_title}</span>
  </nav>

  <header class="hero">
    {page.symbol ? <div class="hero-symbol">{page.symbol}</div> : null}
    <h1>{page.display_title}</h1>
    {page.intro ? <p class="lede">{page.intro}</p> : null}
    {page.meta && page.meta.length > 0 ? (
      <dl class="meta-grid">
        {page.meta.map(m => (
          <div class="meta-pair">
            <dt>{m.label}</dt>
            <dd>{m.value}</dd>
          </div>
        ))}
      </dl>
    ) : null}
  </header>

  <div class="article-body">
    {page.sections.map(s => (
      <section class="section">
        <h2>{s.heading}</h2>
        {s.list && s.list.length > 0 ? (
          <ul class="bullet">
            {s.list.map(item => <li>{item}</li>)}
          </ul>
        ) : (
          paragraphs(s.body).map(p => <p>{p}</p>)
        )}
      </section>
    ))}
  </div>

  {page.related && page.related.length > 0 ? (
    <aside class="related">
      <h2>Related</h2>
      <ul class="related-list">
        {page.related.map(r => (
          <li><a href={r.href}>{r.label}</a></li>
        ))}
      </ul>
    </aside>
  ) : null}

  <script type="application/ld+json" set:html={JSON.stringify(ldBreadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(ldArticle)} />
</article>

<style>
  .article {
    max-width: 720px;
    margin: 0 auto;
    padding: 40px 22px 80px;
    background: var(--t3-post-bg);
    color: var(--t3-post-body-text);
  }
  .crumbs {
    display: flex; gap: 8px; align-items: center; flex-wrap: wrap;
    font-family: var(--t2-font-mono);
    font-size: var(--t1-size-xs);
    color: var(--t3-post-sub-text);
    margin-bottom: 24px;
  }
  .crumbs a { color: var(--t3-post-link); }
  .crumb-current { color: var(--t3-post-h-text); font-weight: 500; }
  .hero { padding: 16px 0 24px; border-bottom: 1px solid var(--t2-border-soft); margin-bottom: 32px; }
  .hero-symbol {
    font-size: var(--t1-size-5xl);
    margin-bottom: 8px;
    line-height: 1;
  }
  .lede {
    font-family: var(--t2-font-heading);
    font-size: var(--t1-size-md);
    font-style: italic;
    color: var(--t3-post-sub-text);
    margin: 8px 0 16px;
    line-height: 1.5;
  }
  .meta-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 12px 24px;
    margin: 16px 0 0;
    padding: 16px;
    background: var(--t2-bg-soft);
    border-radius: var(--t1-radius-md);
  }
  .meta-pair { margin: 0; }
  .meta-pair dt {
    font-family: var(--t2-font-mono);
    font-size: var(--t1-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--t3-post-sub-text);
    margin-bottom: 2px;
  }
  .meta-pair dd { margin: 0; font-size: var(--t1-size-sm); color: var(--t3-post-h-text); font-weight: 500; }
  .section { margin-bottom: 28px; }
  .section h2 {
    font-size: var(--t1-size-xl);
    color: var(--t3-post-h-text);
    margin: 24px 0 8px;
    border-left: 3px solid var(--t3-post-accent);
    padding-left: 12px;
  }
  .section p { color: var(--t3-post-body-text); }
  .bullet { padding-left: 22px; margin: 0 0 16px; }
  .bullet li { margin-bottom: 8px; }
  .related {
    margin-top: 64px; padding-top: 32px;
    border-top: 1px solid var(--t2-border-soft);
  }
  .related h2 {
    font-size: var(--t1-size-lg);
    border-left: none; padding-left: 0;
    margin: 0 0 12px;
    color: var(--t3-post-h-text);
  }
  .related-list {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 10px;
  }
  .related-list a {
    display: block;
    padding: 10px 12px;
    background: var(--t3-card-bg);
    border: 1px solid var(--t3-card-border);
    border-radius: var(--t3-card-radius);
    color: var(--t3-card-text);
    font-size: var(--t1-size-sm);
    transition: box-shadow 0.15s ease, border-color 0.15s ease;
  }
  .related-list a:hover {
    box-shadow: var(--t3-card-shadow-hover);
    border-color: var(--t3-card-accent);
    text-decoration: none;
  }
</style>
